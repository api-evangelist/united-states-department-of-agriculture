          "name": "Get Agricultural Statistics",
          "request": {
            "name": "Get Agricultural Statistics",
            "description": {
              "content": "Query NASS agricultural statistics data using WHAT (commodity, category), WHERE (state, county, watershed), and WHEN (year, period) parameters. Returns a maximum of 50,000 records per request. Supports JSON, CSV, and XML response formats.",
              "type": "text/plain"
            },
            "url": {
              "path": [
                "api_GET",
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [
                {
                  "disabled": false,
                  "key": "key",
                  "value": "<string>",
                  "description": "(Required) NASS API key from quickstats.nass.usda.gov"
                },
                {
                  "disabled": false,
                  "key": "format",
                  "value": "JSON",
                  "description": "Response format"
                },
                {
                  "disabled": false,
                  "key": "commodity_desc",
                  "value": "<string>",
                  "description": "Commodity description (e.g. CORN, WHEAT, CATTLE)"
                },
                {
                  "disabled": false,
                  "key": "statisticcat_desc",
                  "value": "<string>",
                  "description": "Statistics category (e.g. AREA HARVESTED, PRODUCTION, PRICE RECEIVED)"
                },
                {
                  "disabled": false,
                  "key": "year",
                  "value": "<string>",
                  "description": "Four digit year or range using __GE or __LE operators"
                },
                {
                  "disabled": false,
                  "key": "state_name",
                  "value": "<string>",
                  "description": "Full state name"
                },
                {
                  "disabled": false,
                  "key": "agg_level_desc",
                  "value": "<string>",
                  "description": "Geographic aggregation level"
                },
                {
                  "disabled": false,
                  "key": "freq_desc",
                  "value": "<string>",
                  "description": "Frequency period descriptor"
                },
                {
                  "disabled": false,
                  "key": "reference_period_desc",
                  "value": "<string>",
                  "description": "Reference period (e.g. YEAR, JAN, FEB, MARKETING YEAR)"
                },
                {
                  "disabled": false,
                  "key": "unit_desc",
                  "value": "<string>",
                  "description": "Unit of measure (e.g. ACRES, BU, HEAD, $)"
                },
                {
                  "disabled": false,
                  "key": "sector_desc",
                  "value": "<string>",
                  "description": "Economic sector (CROPS, ANIMALS & PRODUCTS, ECONOMICS, etc.)"
                },
