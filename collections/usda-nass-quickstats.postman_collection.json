  "info": {
    "_postman_id": "ed30f5f1-d900-4eb7-bfb2-a1f87966bf8b",
    "name": "USDA NASS Quick Stats API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The USDA National Agricultural Statistics Service (NASS) Quick Stats API provides direct access to official published aggregate estimates related to U.S. agricultural production. Data covers crops, livestock, economics, demographics, and environmental measurements collected through hundreds of sample surveys each year and the Census of Agriculture every five years. An API key from quickstats.nass.usda.gov is required.\n\nContact Support:\n Name: USDA NASS\n Email: NASS.Data.Quality@usda.gov",
      "type": "text/plain"
    }
  }
