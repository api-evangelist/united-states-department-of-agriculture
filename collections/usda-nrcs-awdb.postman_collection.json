  "info": {
    "_postman_id": "71e59eb8-8f29-4506-8528-454649aaae82",
    "name": "USDA NRCS AWDB Water and Climate REST API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The USDA Natural Resources Conservation Service (NRCS) Air and Water Database (AWDB) REST API provides access to snow, water, and climate monitoring data from SNOTEL (SNOw TELemetry) stations, Soil Climate Analysis Network (SCAN) stations, and other monitoring sites. Supports retrieval of station metadata, current conditions, and historical data for water resource management and forecasting.\n\nContact Support:\n Name: USDA NRCS National Water and Climate Center",
      "type": "text/plain"
    }
  }
